{
    "loop_control": {
        "max_steps_per_turn": 5000,
        "max_retries_per_step": 3,
        "reserved_context_size": 50000,
        "compaction_trigger_ratio": 0.85
    },
    "temperature": 0.7,
    "top_p": 0.9,
    "top_k": 50,
    "max_tokens": 65536,
    "thinking_effort": "high",
    "notifications": {
        "enabled": true,
        "sound": true,
        "desktop": true
    },
    "mcp": {
        "enabled": true,
        "servers": []
    },
    "model": {
        "model": "gemini-2.5-pro",
        "max_context_size": 200000,
        "capabilities": [
            "thinking"
        ]
    },
    "provider": {
        "base_url": "https://{REGION}-aiplatform.googleapis.com/v1/projects/{PROJECT_ID}/locations/{REGION}/publishers/google/models/gemini-2.5-pro:generateContent",
        "type": "vertexai",
        "api_key": "sk-xxx",
        "custom_headers": {},
        "oauth": {
            "storage": "file",
            "key": "my-key"
        },
        "env": {
            "GOOGLE_CLOUD_PROJECT": "your-gcp-project-id",
            "GOOGLE_CLOUD_LOCATION": "us-central1",
            "GOOGLE_GENAI_USE_VERTEXAI": "true"
        }
    }
}
